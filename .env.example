# ─────────────────────────────────────────────────────────────
#  K1 Wizard-of-Oz Dashboard — Configuration Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── K1 Robot ─────────────────────────────────────────────────
K1_IP=192.168.0.176
K1_PORT=6666
K1_SSH_USER=booster
# K1_SSH_PASSWORD is set by admin at runtime — not stored here

# ── LLM Provider ─────────────────────────────────────────────
# Options: ollama | anthropic | openai
LLM_PROVIDER=ollama

# ── Ollama (local — no API key required) ─────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Anthropic (session API key entered in dashboard by user) ─
# ANTHROPIC_MODEL is set here; key is session-scoped, not stored
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (session API key entered in dashboard by user) ────
# OPENAI_MODEL is set here; key is session-scoped, not stored
OPENAI_MODEL=gpt-4o-mini

# ── Whisper STT ───────────────────────────────────────────────
# Options: tiny | base | small | medium | large
# Recommendation: base for speed, medium for accuracy
WHISPER_MODEL=base

# ── Piper TTS ─────────────────────────────────────────────────
PIPER_VOICE=en_US-lessac-medium
# Full path to your downloaded .onnx voice model
PIPER_VOICE_PATH=./voices/en_US-lessac-medium.onnx

# ── Flask Server ──────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Change this to a strong secret for production use
FLASK_SECRET_KEY=change-me-before-deploying

# ── Admin Console ─────────────────────────────────────────────
# Set a strong password. This is hashed on first run.
ADMIN_PASSWORD=changeme123

# ── NVIDIA Isaac Sim (optional) ───────────────────────────────
# IP of the machine running Isaac Sim
ISAAC_SERVER_IP=192.168.0.100
ISAAC_STREAM_PORT=8211
